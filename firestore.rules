rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /blogs/{blogId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.tenantId;
    }
    match /jobs/{jobId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.tenantId;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
