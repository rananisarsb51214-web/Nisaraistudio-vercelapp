export class MarketEngine {
  private tasks: MarketTask[] = [];

  postTask(task: MarketTask) {
    this.tasks.push(task);
  }

  assignTask(agentId: string) {
    const task = this.tasks.find(t => t.status === "open");

    if (!task) return null;

    task.status = "assigned";
    task.assignedAgentId = agentId;

    return task;
  }

  completeTask(taskId: string, success: boolean) {
    const task = this.tasks.find(t => t.id === taskId);

    if (!task) return;

    task.status = "completed";
  }
}import { MarketEngine } from "../market/market.engine";

export class AgentWorker {
  constructor(
    private id: string,
    private market: MarketEngine
  ) {}

  async loop() {
    while (true) {
      const task = this.market.assignTask(this.id);

      if (!task) {
        await this.sleep(300);
        continue;
      }

      const result = await this.execute(task);

      this.market.completeTask(task.id, true);

      this.reward(task.priceCredits);
    }
  }

  async execute(task: any) {
    return {
      result: `processed ${task.type}`
    };
  }

  reward(credits: number) {
    console.log(`[AGENT ${this.id}] earned ${credits} credits`);
  }

  sleep(ms: number) {
    return new Promise(r => setTimeout(r, ms));
  }
}export function getTenantContext(req: any) {
