rules:
  - host: workspaces.nisar.my-company.com
    http:
      paths:
        - path: /collab
          pathType: Prefix
          backend:
            service:
              name: {{ include "developer-workspace.fullname" . }}
              port:
                number: 1234
        - path: /
          pathType: Prefix
          backend:
            service:
              name: {{ include "developer-workspace.fullname" . }}
              port:
                number: 3000